packages:
  yum:
    python3-devel: []
    gcc: []
    gcc-c++: []
    make: []
    openssl-devel: []
    bzip2-devel: []
    sqlite-devel: []
    zlib-devel: []
    libffi-devel: []

container_commands:
  01_install_dependencies:
    command: |
      source /var/app/venv/*/bin/activate
      pip install -q --upgrade pip setuptools wheel
    ignoreErrors: true
    
  02_install_ml_requirements:
    command: |
      source /var/app/venv/*/bin/activate
      pip install -q scikit-learn==1.3.0 --only-binary=:all: || pip install scikit-learn==1.3.0
    ignoreErrors: true
    
  03_check_sklearn:
    command: |
      source /var/app/venv/*/bin/activate
      python -c "import sklearn; print(f'scikit-learn version: {sklearn.__version__}')"
    ignoreErrors: true

  04_create_app_log_dir:
    command: "mkdir -p /var/app/current/logs && chmod 755 /var/app/current/logs"
    leader_only: true
    ignoreErrors: true
