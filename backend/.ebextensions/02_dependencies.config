packages:
  yum:
    python3-devel: []
    gcc: []
    gcc-c++: []
    make: []
    openssl-devel: []
    bzip2-devel: []
    sqlite-devel: []
    zlib-devel: []
    libffi-devel: []

container_commands:
  01_install_dependencies:
    command: |
      source /var/app/venv/*/bin/activate
      pip install -q --upgrade pip setuptools wheel
    ignoreErrors: true
    
  02_create_app_log_dir:
    command: "mkdir -p /var/app/current/logs && chmod 755 /var/app/current/logs"
    leader_only: true
    ignoreErrors: true
